generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TeamType {
  CMTR
  CMT
}

enum CrisisStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  CLOSED
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  mobileNumber String?
  role         Role
  isActive     Boolean  @default(true)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Team {
  id             String   @id @default(uuid())
  teamType       TeamType
  teamName       String
  description    String?
  teamLeadUserId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Crisis {
  id                String       @id @default(uuid())
  crisisCode        String       @unique
  title             String
  description       String
  severity          String
  category          String
  location          String
  status            CrisisStatus @default(OPEN)
  createdBy         String
  assignedCmtrId    String?
  resolutionSummary String?
  closedBy          String?
  closedAt          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}
